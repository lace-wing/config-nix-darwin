# The syntax is "key = value". The whitespace around the equals doesn't matter.

keybind = global:cmd+shift+s=toggle_quick_terminal

font-family = MonaspiceAr NF
font-family-bold = MonaspiceNe NF
font-family-italic = MonaspiceRn NF
font-family-bold-italic = MonaspiceXe NF

font-size = 16

# neat dark
# theme = Nvim Dark

# dark dim green-earth
# theme = Black Metal (Nile)
# cursor-color = #777755

# vibrant earthy
# theme = Arthur

# custom
theme = Hanekawa

macos-titlebar-style = hidden

background-opacity = 0.6
background-blur-radius = 0

# alt fix
macos-option-as-alt = left

